# Puerto del servidor (por defecto 3000)
PORT=3000

# Clave secreta para firmar los tokens JWT - Cámbiala por una segura en producción
JWT_SECRET=tu_clave_secreta_aqui

# Zona horaria del negocio en formato IANA (ejemplo: America/Argentina/Buenos_Aires, Europe/Madrid)
BUSINESS_TIMEZONE=America/Argentina/Buenos_Aires

# Offset horario del negocio en horas respecto a UTC (ejemplo: Argentina es -3)
# NOTA: Este offset ya no se usa en server.js, pero se mantiene por compatibilidad con scripts como seedTurnos.js
BUSINESS_TIMEZONE_OFFSET=-3

# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
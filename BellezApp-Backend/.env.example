# Puerto del servidor (por defecto 3000)
PORT=3000

# Clave secreta para firmar los tokens JWT - Cámbiala por una segura en producción
JWT_SECRET=tu_clave_secreta_aqui

# Offset horario del negocio en horas respecto a UTC (ejemplo: Argentina es -3)
BUSINESS_TIMEZONE_OFFSET=-3

# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000